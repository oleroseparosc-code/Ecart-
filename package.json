{
  "name": "hospital-inventory-check",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:data": "py scripts/extract_inventory.py",
    "validate:data": "py scripts/validate_inventory.py",
    "test": "vitest run --no-watch --reporter=basic --testTimeout=10000 --config vitest.config.ts",
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "vitest": "^4.1.9"
  }
}
